# HexMetrics Production Environment
# Copy to .env.production and fill in real values

NODE_ENV=production
PORT=3001

# Domain (used by Caddyfile)
DOMAIN=hexmetrics.example.com

# Auth
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_A_DIFFERENT_64_CHAR_STRING
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# CORS — comma-separated origins
ALLOWED_ORIGINS=https://hexmetrics.example.com

# Database (SQLite path inside container)
DB_PATH=./server/data/hexmetrics.db
